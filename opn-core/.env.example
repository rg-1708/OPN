# HTTP server bind address
OPN_BIND=127.0.0.1:8080
# Prometheus metrics bind address
OPN_METRICS_BIND=127.0.0.1:9090

# Runtime pool, non-BYPASSRLS role (created by migration 0001)
DATABASE_URL=postgres://opn_app:opn@localhost:5432/opn
# Owner role, used only to run migrations at startup
OPN_MIGRATE_DATABASE_URL=postgres://opn_migrate:opn@localhost:5432/opn

REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO in dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=opn
S3_KEY=opn
S3_SECRET=opnsecret

# Auth
OPN_JWT_SECRET=dev-secret-change-me
OPN_SESSION_TTL_SECS=600

OPN_REPLICAS=1

RUST_LOG=opn_core=info
