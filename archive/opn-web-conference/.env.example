# Core HTTP base URL (a stock OPN Core dev stack). dev-auth mints against this; Vite proxies /ws here.
OPN_CORE_URL=http://localhost:8080
# Tenant API key. SERVER-SIDE ONLY (dev-auth). Never exposed to the browser.
OPN_TENANT_API_KEY=
# dev-auth listen port (optional).
DEV_AUTH_PORT=8787
# TURN relay for WebRTC calls (optional). OPERATOR/CORE-SIDE coturn config — NOT
# read by this template. The browser gets its ICE servers from Core's calls.state
# snapshot (ice_servers); set this where your Core reads its coturn config.
TURN_URL=
