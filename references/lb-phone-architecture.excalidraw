verticalAlign": "top", "containerId": null, "originalText": "native exports", "lineHeight": 1.25}, {"id": "arr-0436", "x": 1013.5999999999999, "y": 1259.0, "width": -143.19999999999982, "height": 310.0, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "dashed", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 437007, "version": 1, "versionNonce": 5694, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "arrow", "points": [[0, 0], [-143.19999999999982, 310.0]], "startArrowhead": null, "endArrowhead": "arrow", "startBinding": {"elementId": "rect-0295", "focus": 0.0, "gap": 4}, "endBinding": {"elementId": "rect-0355", "focus": 0.0, "gap": 4}, "lastCommittedPoint": null, "elbowed": false}, {"id": "txt-0439", "x": 896.76, "y": 1398.0, "width": 90.47999999999999, "height": 15, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 440007, "version": 1, "versionNonce": 5733, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 12, "fontFamily": 2, "text": "voice targets", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "voice targets", "lineHeight": 1.25}, {"id": "arr-0442", "x": 1324.8, "y": 1259.0, "width": -211.19999999999982, "height": 310.0, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "dashed", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 443007, "version": 1, "versionNonce": 5772, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "arrow", "points": [[0, 0], [-211.19999999999982, 310.0]], "startArrowhead": null, "endArrowhead": "arrow", "startBinding": {"elementId": "rect-0301", "focus": 0.0, "gap": 4}, "endBinding": {"elementId": "rect-0361", "focus": 0.0, "gap": 4}, "lastCommittedPoint": null, "elbowed": false}, {"id": "txt-0445", "x": 1163.52, "y": 1398.0, "width": 111.35999999999999, "height": 15, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 446007, "version": 1, "versionNonce": 5811, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 12, "fontFamily": 2, "text": "presigned upload", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "presigned upload", "lineHeight": 1.25}, {"id": "arr-0448", "x": 538.8, "y": 1200, "width": -308.79999999999995, "height": -114, "angle": 0, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "dashed", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 449007, "version": 1, "versionNonce": 5850, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "arrow", "points": [[0, 0], [-308.79999999999995, -114]], "startArrowhead": null, "endArrowhead": "arrow", "startBinding": {"elementId": "rect-0283", "focus": 0.0, "gap": 4}, "endBinding": {"elementId": "rect-0202", "focus": 0.0, "gap": 4}, "lastCommittedPoint": null, "elbowed": false}, {"id": "txt-0451", "x": 321.76, "y": 1127.0, "width": 125.27999999999999, "height": 15, "angle": 0, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 452007, "version": 1, "versionNonce": 5889, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 12, "fontFamily": 2, "text": "SetPhone / item id", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "SetPhone / item id", "lineHeight": 1.25}, {"id": "rect-0454", "x": 1680, "y": 100, "width": 700, "height": 340, "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "#f1f8ff", "fillStyle": "solid", "strokeWidth": 1.5, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 455007, "version": 1, "versionNonce": 5928, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "rectangle"}, {"id": "txt-0457", "x": 1696, "y": 112, "width": 391.5, "height": 18, "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 458007, "version": 1, "versionNonce": 5967, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 15, "fontFamily": 2, "text": "REQUEST / RESPONSE FLOW   (Notes app example)", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "REQUEST / RESPONSE FLOW   (Notes app example)", "lineHeight": 1.25}, {"id": "txt-0460", "x": 1698, "y": 144, "width": 410.64, "height": 255, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 461007, "version": 1, "versionNonce": 6006, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 12, "fontFamily": 2, "text": "1.  React app  ->  fetch('https://lb-phone/Notes', {action})\n2.  client Notes.lua  RegisterNUICallback  ->\n        TriggerCallback('notes:get', cb, ...)\n3.  net  ->  lb-phone:cb:notes:get  (requestId)\n        stored in waitingCallbacks · 120s timeout\n4.  server  RegisterCallback  (via BaseCallback):\n        resolves GetEquippedPhoneNumber(src),\n        checks preventSpam / rateLimit\n5.  oxmysql  ->  SELECT * FROM phone_notes\n        WHERE phone_number = ?\n6.  server  ->  lb-phone:cb:response  (src, id, rows)\n7.  client resolves stored cb  ->  SendNUIAction\n8.  React re-renders  (ok)\n\nServer->client push (new msg/call/notif) uses the\nmirror path: TriggerClientEvent -> SendNUIAction;\nno-service/airplane mode queues & replays events.", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "1.  React app  ->  fetch('https://lb-phone/Notes', {action})\n2.  client Notes.lua  RegisterNUICallback  ->\n        TriggerCallback('notes:get', cb, ...)\n3.  net  ->  lb-phone:cb:notes:get  (requestId)\n        stored in waitingCallbacks · 120s timeout\n4.  server  RegisterCallback  (via BaseCallback):\n        resolves GetEquippedPhoneNumber(src),\n        checks preventSpam / rateLimit\n5.  oxmysql  ->  SELECT * FROM phone_notes\n        WHERE phone_number = ?\n6.  server  ->  lb-phone:cb:response  (src, id, rows)\n7.  client resolves stored cb  ->  SendNUIAction\n8.  React re-renders  (ok)\n\nServer->client push (new msg/call/notif) uses the\nmirror path: TriggerClientEvent -> SendNUIAction;\nno-service/airplane mode queues & replays events.", "lineHeight": 1.25}, {"id": "rect-0463", "x": 1680, "y": 460, "width": 700, "height": 620, "angle": 0, "strokeColor": "#6741d9", "backgroundColor": "#f6f3ff", "fillStyle": "solid", "strokeWidth": 1.5, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 464007, "version": 1, "versionNonce": 6045, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "rectangle"}, {"id": "txt-0466", "x": 1696, "y": 472, "width": 174.0, "height": 18, "angle": 0, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 467007, "version": 1, "versionNonce": 6084, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 15, "fontFamily": 2, "text": "KEY DESIGN DECISIONS", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "KEY DESIGN DECISIONS", "lineHeight": 1.25}, {"id": "txt-0469", "x": 1698, "y": 502, "width": 380.19, "height": 575, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 470007, "version": 1, "versionNonce": 6123, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 11.5, "fontFamily": 2, "text": "• Encrypted core, open seams.  client.lua/server.lua +\n  app logic are FXAP-encrypted; lib/, shared/, config/\n  and every custom/ bridge are escrow-ignored & editable.\n  Boundary = policy/mechanism + portability seam.\n\n• One RPC backbone.  Whole surface = 2 net events keyed\n  by requestId, both directions; asymmetric timeouts\n  (120s client / 15s server), per-source rate-limit,\n  anti-spam in-flight lock.  BaseCallback trusts the\n  server-resolved phone number, never client input.\n\n• Adapter/bridge pattern for portability.  Flat global\n  contract, each file guarded by\n  `if Config.X ~= \"Y\" then return end` -> exactly one\n  impl loads.  6 frameworks · 6 inventories · many\n  housing/voice scripts behind one uniform surface.\n\n• Self-configuring bootstrap.  Framework, inventory,\n  voice & housing auto-detected via GetResourceState;\n  config = user file + encrypted defaults, load order\n  by FiveM alphabetical glob.\n\n• phone_number = universal join key.  ~all 75 tables\n  reference phone_phones via CASCADE FKs (crypto/mail\n  keyed differently on purpose).  ~30 DB triggers keep\n  social counters atomic in-engine.\n\n• Self-healing schema.  DatabaseChecker diffs live DB\n  vs canonical defaultTables every boot, auto-ALTERs\n  drift or emits fix.sql.\n\n• Product-grade extension API.  Register/Trigger/Await,\n  AddKeyBind, AddCheck veto hooks, SendNotification,\n  custom-app iframe SDK — all exported, per-resource\n  tracked, auto-torn-down on onResourceStop.\n\n• Binaries & secrets off the game server.  Media uploads\n  go browser->external storage via presigned URLs;\n  URLs pass an allow/block host guard both sides;\n  secrets live in escrow-ignored server/apiKeys.lua.", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "• Encrypted core, open seams.  client.lua/server.lua +\n  app logic are FXAP-encrypted; lib/, shared/, config/\n  and every custom/ bridge are escrow-ignored & editable.\n  Boundary = policy/mechanism + portability seam.\n\n• One RPC backbone.  Whole surface = 2 net events keyed\n  by requestId, both directions; asymmetric timeouts\n  (120s client / 15s server), per-source rate-limit,\n  anti-spam in-flight lock.  BaseCallback trusts the\n  server-resolved phone number, never client input.\n\n• Adapter/bridge pattern for portability.  Flat global\n  contract, each file guarded by\n  `if Config.X ~= \"Y\" then return end` -> exactly one\n  impl loads.  6 frameworks · 6 inventories · many\n  housing/voice scripts behind one uniform surface.\n\n• Self-configuring bootstrap.  Framework, inventory,\n  voice & housing auto-detected via GetResourceState;\n  config = user file + encrypted defaults, load order\n  by FiveM alphabetical glob.\n\n• phone_number = universal join key.  ~all 75 tables\n  reference phone_phones via CASCADE FKs (crypto/mail\n  keyed differently on purpose).  ~30 DB triggers keep\n  social counters atomic in-engine.\n\n• Self-healing schema.  DatabaseChecker diffs live DB\n  vs canonical defaultTables every boot, auto-ALTERs\n  drift or emits fix.sql.\n\n• Product-grade extension API.  Register/Trigger/Await,\n  AddKeyBind, AddCheck veto hooks, SendNotification,\n  custom-app iframe SDK — all exported, per-resource\n  tracked, auto-torn-down on onResourceStop.\n\n• Binaries & secrets off the game server.  Media uploads\n  go browser->external storage via presigned URLs;\n  URLs pass an allow/block host guard both sides;\n  secrets live in escrow-ignored server/apiKeys.lua.", "lineHeight": 1.25}, {"id": "rect-0472", "x": 1680, "y": 1100, "width": 700, "height": 210, "angle": 0, "strokeColor": "#495057", "backgroundColor": "#f8f9fa", "fillStyle": "solid", "strokeWidth": 1.5, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 473007, "version": 1, "versionNonce": 6162, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "rectangle"}, {"id": "txt-0475", "x": 1696, "y": 1112, "width": 52.199999999999996, "height": 18, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 476007, "version": 1, "versionNonce": 6201, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 15, "fontFamily": 2, "text": "LEGEND", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "LEGEND", "lineHeight": 1.25}, {"id": "txt-0478", "x": 1698, "y": 1142, "width": 410.64, "height": 180, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 479007, "version": 1, "versionNonce": 6240, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "type": "text", "fontSize": 12, "fontFamily": 2, "text": "(enc)  = escrow-encrypted core (behavior inferred)\n(!)  = notable engineering (self-heal / central identity)\n(rec)  = recommended integration\n\nBands top->bottom = request depth (UI -> DB).\nColors:  blue NUI · green Lua runtime · gold RPC spine\n         purple bridges · pink persistence · gray external.\n\nArrows:   solid orange = request down\n          dashed green = response up\n          pink = SQL   ·   purple = bridge call\n          dashed gray = external I/O", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "(enc)  = escrow-encrypted core (behavior inferred)\n(!)  = notable engineering (self-heal / central identity)\n(rec)  = recommended integration\n\nBands top->bottom = request depth (UI -> DB).\nColors:  blue NUI · green Lua runtime · gold RPC spine\n         purple bridges · pink persistence · gray external.\n\nArrows:   solid orange = request down\n          dashed green = response up\n          pink = SQL   ·   purple = bridge call\n          dashed gray = external I/O", "lineHeight": 1.25}], "appState": {"gridSize": null, "viewBackgroundColor": "#ffffff"}, "files": {}}